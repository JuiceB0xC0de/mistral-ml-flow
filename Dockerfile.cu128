# syntax=docker/dockerfile:1
###############################################################################
# Atlas ML image — CUDA 12.8 / torch 2.7 variant
#
# Single-purpose runtime for Qwen3.5-family models (including allenai/tmax)
# that require flash-attn 2 + causal-conv1d + mamba-ssm prebuilt wheels.
#
# Anchor: Python 3.11, torch 2.7.0 cu128
###############################################################################

FROM nvidia/cuda:12.8.0-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    PIP_NO_CACHE_DIR=1 \
    CUDA_HOME=/usr/local/cuda-12.8 \
    PATH=/usr/local/cuda-12.8/bin:/usr/local/bin:/usr/bin:/bin

RUN apt-get update && apt-get install -y --no-install-recommends \
      software-properties-common \
 && add-apt-repository ppa:deadsnakes/ppa \
 && apt-get update && apt-get install -y --no-install-recommends \
      python3.11 python3.11-dev \
      git curl ca-certificates build-essential ninja-build \
 && rm -rf /var/lib/apt/lists/* \
 && curl -sS https://bootstrap.pypa.io/get-pip.py | python3.11 \
 && python3.11 -m pip install --upgrade pip setuptools wheel packaging psutil "cmake>=3.30" nvtx \
 && ln -sf /usr/bin/python3.11 /usr/local/bin/python \
 && ln -sf /usr/bin/python3.11 /usr/local/bin/python3 \
 && printf '#!/bin/sh\nexec python3.11 -m pip "$@"\n' > /usr/local/bin/pip \
 && chmod +x /usr/local/bin/pip \
 && ln -sf /usr/local/bin/pip /usr/local/bin/pip3 \
 && python3.11 -m pip install "nvidia-ml-py>=12.560"

WORKDIR /workspace

# Anchor torch to the same CUDA/Python wheel ABI the extension wheels expect.
RUN pip install torch==2.7.0 \
      --index-url https://download.pytorch.org/whl/cu128

# Prebuilt CUDA extension wheels requested for Qwen3.5 / TMax linear-attention models.
RUN pip install --no-build-isolation \
      "https://github.com/mjun0812/flash-attention-prebuild-wheels/releases/download/v0.7.16/flash_attn-2.8.3+cu128torch2.7-cp311-cp311-linux_x86_64.whl" \
      "https://github.com/Dao-AILab/causal-conv1d/releases/download/v1.6.2.post1/causal_conv1d-1.6.2.post1+cu12torch2.7cxx11abiTRUE-cp311-cp311-linux_x86_64.whl" \
      "https://github.com/state-spaces/mamba/releases/download/v2.3.0/mamba_ssm-2.3.0+cu12torch2.7cxx11abiTRUE-cp311-cp311-linux_x86_64.whl"

# flash-linear-attention (FLA) for Qwen3.5's native fast linear/delta-net path.
# FLA v0.5.0+ ships on PyPI; [cuda] extras pull the CUDA backend. Pin triton
# to the version FLA expects for torch 2.7.0 to avoid runtime symbol mismatches.
RUN pip install --no-build-isolation \
      "triton==3.3.0" \
      "flash-linear-attention[cuda]"

RUN pip install \
      "numpy==1.26.4" \
      "mistral-common==1.11.4" \
      "accelerate==1.14.0" \
      "huggingface_hub==1.16.1" \
      "hf_transfer==0.1.9" \
      "safetensors==0.8.0" \
      "orjson==3.11.9" \
      "pandas==3.0.3" \
      "scikit-learn==1.9.0" \
      "scipy==1.17.1" \
      "matplotlib==3.11.0" \
      "seaborn==0.13.2" \
      "tqdm==4.68.3" \
      "sentencepiece==0.2.1" \
      "protobuf==3.20.3" \
      "tokenizers==0.22.2" \
      "zarr==2.18.7" \
      "numcodecs==0.15.1" \
      "fasteners==0.20" \
      "asciitree==0.3.3" \
      "wrapt==2.2.2" \
      "Deprecated==1.3.1" \
      "nvidia-ml-py>=12.560" \
      "b2sdk>=2.0.0"

# Bleeding-edge transformers is required for Qwen3.5-family models such as
# allenai/tmax-2b and allenai/tmax-27b. Pinning a release version breaks loading.
RUN pip install --no-cache-dir --no-build-isolation \
      "git+https://github.com/huggingface/transformers.git"

COPY scripts/ /usr/local/bin/
RUN chmod +x /usr/local/bin/start.sh \
      /usr/local/bin/atlas-clone \
      /usr/local/bin/atlas-run-ministral \
      /usr/local/bin/atlas-run-vibethinker \
      /usr/local/bin/atlas-run-qwen35

RUN python -c "import torch, flash_attn, transformers, numpy, orjson, sklearn; \
      from transformers import AutoConfig; \
      AutoConfig.for_model('qwen3_5'); AutoConfig.for_model('mistral3'); \
      import pynvml; pynvml.nvmlInit(); print('pynvml OK'); \
      import b2sdk; print('b2sdk OK'); \
      print('torch', torch.__version__); \
      print('flash-attn', flash_attn.__version__); \
      print('transformers', transformers.__version__); \
      print('mistral-common', __import__('mistral_common').__version__); \
      print('cuda', torch.version.cuda); \
      assert torch.__version__.startswith('2.7'), torch.__version__" \
 && pip show causal-conv1d mamba-ssm flash-linear-attention | grep -E "^(Name|Version|Location):"

CMD ["/usr/local/bin/start.sh"]
